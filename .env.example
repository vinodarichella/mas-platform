# Copy to .env and fill in your values

JWT_SECRET=change-me-in-production-use-a-long-random-256-bit-key
INTERNAL_API_KEY=change-me-in-production

# ── Azure OpenAI (primary provider) ───────────────────────────────────────────
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-02-01

# ── Databricks Model Serving (OpenAI-compatible) ──────────────────────────────
DATABRICKS_HOST=https://adb-<workspace-id>.azuredatabricks.net
DATABRICKS_TOKEN=

# ── Optional providers ─────────────────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
